# Includes: java, maven, intellij, macos

### Universal ###
# Common files that should be ignored in all projects

# Logs
*.log

# Temporary files
*.tmp
*~
*.bak

# Environment files (containing secrets, API keys, credentials)
.env
*.env
.env.*

# Local configuration that shouldn't be shared
*.local

### Java ###
# Compiled bytecode and packaged artifacts
*.class
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# JVM crash logs
hs_err_pid*
replay_pid*

# Generic build output directories
bin/
build/

# Eclipse-specific project files
.classpath
.project
.settings/
.apt_generated/
.factorypath
.springBeans
*.launch

### Maven ###
# Build output
target/

# Maven Wrapper — intentionally excluded.
mvnw
mvnw.cmd

# Release / versions plugin artifacts
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
*.versionsBackup

# Shade plugin / build-number plugin artifacts
dependency-reduced-pom.xml
buildNumber.properties

# Build status and generated-source metadata
maven-status/
maven-archiver/
generated-sources/
generated-test-sources/
maven-compiler-plugin/
maven-metadata.xml
maven-metadata-local.xml
.maven-classpath

# Eclipse m2e integration
maven-eclipse.xml

# Local repository cache directories (various naming conventions)
.m2/
repository/
.mvn/
maven/
.maven/
maven-repository/
.maven-cache/
.maven_repos/

### Intellij ###
# Core IDE project/workspace metadata
.idea/
*.iml
*.iws
*.ipr
.idea_modules/
out/

# Backup files
*.iml.bak
*.ipr.bak
*.iws.bak
.idea_backup/

### Macos ###
# Finder metadata
.DS_Store
.DS_Store?
.AppleDouble
*.AppleDouble
.LSOverride
Icon
._*

# Volume / disk image artifacts
.VolumeIcon.icns
.apdisk
*.icloud

# Files that can appear on network or external volumes
.Spotlight-V100
.Spotlight-V100/
.TemporaryItems
Temporary Items
.Trashes
.Trashes/
Network Trash Folder
Network Trash Folder/
.com.apple.timemachine.donotpresent
.fseventsd
.DocumentRevisions-V100
.AppleDB
*.AppleDB
.AppleDB/
.AppleDesktop
.AppleDesktop/
*.swp
