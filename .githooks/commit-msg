#!/bin/sh

# Path to the temporary file containing the commit message
commit_message_file=$1

# Extract the very first line (the subject line/title)
subject_line=$(head -1 "$commit_message_file")

# Skip validation for auto-generated merge commits from `git merge`, `git pull` or GitHub's "Update branch" button.
# These aren't hand-written commits and don't follow Conventional Commits format by design.
case "$subject_line" in "Merge "*)
  echo "🟡 Merge commit detected — skipping subject line validation"
  exit 0
  ;;
esac

subject_length=${#subject_line}

if [ "$subject_length" -gt 70 ]; then
  echo "🔴 Commit rejected: subject line is $subject_length characters (limit: 70, excess: $((subject_length - 70)))"
  exit 1
fi

pattern="^(build|chore|ci|docs|feat|fix|perf|refactor|revert|test)(\([a-z0-9_-]+\))?: [^ A-Z].*"

if ! echo "$subject_line" | grep -qE "$pattern"; then
  echo "🔴 Commit rejected: subject line must follow Conventional Commits format"
  echo "     Expected:    <type>: <description> (e.g. \"chore: add commit subject line length and format enforcement\")"
  echo "     Valid types: build, chore, ci, docs, feat, fix, perf, refactor, revert, test"
  echo "     Note:        description must start with a lowercase letter (e.g. \"add\", not \"Add\")"
  exit 1
fi

# IntelliJ IDEA does not show this but terminal does
echo "🟢 Commit accepted: subject line follows Conventional Commits format"
